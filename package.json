{
  "type": "module",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7"
  },
  "scripts": {
    "prepare": "husky",
    "commitlint:check": "npx commitlint --from HEAD~1 --to HEAD --verbose",
